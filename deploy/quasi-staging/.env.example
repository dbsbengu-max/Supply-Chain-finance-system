# EA-036 Quasi Staging local/shared validation environment.
# Copy to .env. Values here are non-production demo credentials only.

SCF_ENV_NAME=quasi-staging

# Host-side DB access for pilot scripts.
SCF_DB_HOST=localhost
SCF_DB_PORT=15432
SCF_DB_NAME=scf
SCF_DB_USER=scf
SCF_DB_PASSWORD=scf_qs_pass_20260531
SCF_DOCKER_PG_CONTAINER=scf-qs-postgres

# Backend health URL as seen from the machine running scripts.
SCF_API_HEALTH_URL=http://localhost:18080/api/v1/actuator/health

# Container port mapping.
QS_POSTGRES_PORT=15432
QS_BACKEND_PORT=18080
QS_WEB_PORT=15173

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Demo-only secrets. Replace when this environment is shared beyond local validation.
SCF_JWT_SECRET=qs-local-jwt-secret-20260531-minimum-256-bits-do-not-use-in-prod
SCF_JWT_EXPIRATION_MS=86400000
SCF_BANK_CALLBACK_TOKEN=qs-local-bank-callback-token-20260531

SCF_FILE_STORAGE_DIR=/var/scf/uploads
SCF_FILE_STORAGE_BUCKET=quasi-staging-local
SCF_FILE_MAX_SIZE_BYTES=10485760

SCF_OUTBOX_POLL_INTERVAL_MS=30000
SCF_COMPENSATION_POLL_INTERVAL_MS=30000
SCF_IDEMPOTENCY_RETENTION_DAYS=180

SCF_LOG_LEVEL_ROOT=INFO
SCF_LOG_LEVEL_COM_SCF=INFO
SCF_DEV_PASSWORD_BOOTSTRAP=false
