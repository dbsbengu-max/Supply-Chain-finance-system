# EA-046 供应商 Sandbox 联调 — copy to .env.esign-sandbox (never commit secrets)
#   copy .env.esign-sandbox.example .env.esign-sandbox
#   fill vendor sandbox credentials, then:
#   .\scripts\run-ea046-sandbox-evidence.ps1 -EnvFile .\.env.esign-sandbox

# ── Platform API (must include context-path /api/v1) ───────────────────────
SCF_BASE_URL=http://127.0.0.1:8080/api/v1
SCF_API_HEALTH_URL=http://127.0.0.1:8080/api/v1/actuator/health

# ── Sandbox login (platform admin with DOCUMENT_CONTRACT_SIGN + SAGA_OPS) ────
SCF_LOGIN_NAME=platform_admin
SCF_LOGIN_PASSWORD=CHANGE_ME_SANDBOX_LOGIN_PASSWORD
SCF_OPERATOR_ID=OP001
SCF_PROJECT_ID=PJ001

# ── Test document (review APPROVED, sign_status PENDING, has PDF file ref) ─
SCF_ESIGN_DOCUMENT_ID=DOC_SANDBOX_SIGN_001

# ── Vendor sandbox (from official API doc) ─────────────────────────────────
SCF_ENV_NAME=vendor-sandbox
SCF_VENDOR_NAME=ExampleEsign
SCF_VENDOR_DOC_VERSION=2026-Q2
SCF_CONTRACT_SIGN_DEFAULT_PROVIDER=ESIGN_HTTP
SCF_CONTRACT_SIGN_CALLBACK_TOKEN=CHANGE_ME_SANDBOX_CALLBACK_HMAC
SCF_CONTRACT_SIGN_CALLBACK_VERIFICATION_MODE=TIMESTAMP_NONCE_SIGNATURE
SCF_CONTRACT_SIGN_CALLBACK_SIGNATURE_WINDOW_SECONDS=300
SCF_CONTRACT_SIGN_COMPENSATION_POOL_ENABLED=true
SCF_CONTRACT_SIGN_HTTP_PROVIDER_ENABLED=true
SCF_CONTRACT_SIGN_HTTP_PROVIDER_CODE=ESIGN_HTTP
SCF_CONTRACT_SIGN_HTTP_BASE_URL=https://sandbox.esign-vendor.example.com
SCF_CONTRACT_SIGN_HTTP_CREATE_PATH=/sign/create
SCF_CONTRACT_SIGN_HTTP_STATUS_PATH=/sign/status/{externalSignRef}
SCF_CONTRACT_SIGN_HTTP_APP_ID=CHANGE_ME_SANDBOX_APP_ID
SCF_CONTRACT_SIGN_HTTP_APP_SECRET=CHANGE_ME_SANDBOX_APP_SECRET
SCF_CONTRACT_SIGN_HTTP_OUTBOUND_AUTH_MODE=HMAC_SHA256
# RSA/SM2: set OUTBOUND_AUTH_MODE and PRIVATE_KEY_PEM instead of APP_SECRET
# SCF_CONTRACT_SIGN_HTTP_PRIVATE_KEY_PEM=
SCF_CONTRACT_SIGN_HTTP_PLATFORM_TRACE_HEADER=X-Request-Id
SCF_CONTRACT_SIGN_HTTP_VENDOR_REQUEST_ID_HEADER=X-Vendor-Request-Id
SCF_CONTRACT_SIGN_HTTP_VENDOR_TRACE_ID_HEADER=X-Vendor-Trace-Id

# Callback URL registered at vendor console (for their outbound, not used by script)
SCF_VENDOR_CALLBACK_URL=https://your-scf-host.example.com/api/v1/integrations/contracts/sign-callback

# ── Optional DB export (PostgreSQL on sandbox/staging) ───────────────────────
SCF_DB_HOST=127.0.0.1
SCF_DB_PORT=5432
SCF_DB_NAME=scf
SCF_DB_USER=scf
SCF_DB_PASSWORD=CHANGE_ME_SANDBOX_DB_PASSWORD

# ── Evidence run metadata ──────────────────────────────────────────────────
# EA046_RUN_BY=zhangsan
# EA046_VENDOR_TICKET=VENDOR-SBX-2026-001
