# EA-048 外部真实供应商 Sandbox 复跑 + Go/No-Go 签核包
#   copy .env.ea048-real-vendor.example .env.ea048-real-vendor
#   fill ALL CHANGE_ME values (never commit secrets)
#   .\scripts\run-ea048-real-vendor-gonogo.ps1 -EnvFile .\.env.ea048-real-vendor

# ── Target SCF environment (staging / pilot — NOT local-quasi-sandbox) ───────
SCF_BASE_URL=https://scf-staging.example.com/api/v1
SCF_API_HEALTH_URL=https://scf-staging.example.com/api/v1/actuator/health
SCF_ENV_NAME=vendor-sandbox

# ── Login (DOCUMENT_CONTRACT_SIGN + CONTRACT_SIGN_CONFIG_VIEW + SAGA_OPS) ─
SCF_LOGIN_NAME=platform_admin
SCF_LOGIN_PASSWORD=CHANGE_ME_STAGING_LOGIN_PASSWORD
SCF_OPERATOR_ID=OP001
SCF_PROJECT_ID=PJ_PILOT_001

# ── Test document on staging DB ─────────────────────────────────────────────
SCF_ESIGN_DOCUMENT_ID=DOC_SANDBOX_SIGN_001

# ── Real vendor sandbox credentials ─────────────────────────────────────────
SCF_VENDOR_NAME=ExampleEsign
SCF_VENDOR_DOC_VERSION=2026-Q2
SCF_VENDOR_CALLBACK_URL=https://scf-staging.example.com/api/v1/integrations/contracts/sign-callback
SCF_VENDOR_TICKET=VENDOR-SBX-2026-001

SCF_CONTRACT_SIGN_DEFAULT_PROVIDER=ESIGN_HTTP
SCF_CONTRACT_SIGN_CALLBACK_TOKEN=CHANGE_ME_CALLBACK_HMAC_MIN_32_CHARS
SCF_CONTRACT_SIGN_CALLBACK_VERIFICATION_MODE=TIMESTAMP_NONCE_SIGNATURE
SCF_CONTRACT_SIGN_COMPENSATION_POOL_ENABLED=true
SCF_CONTRACT_SIGN_HTTP_PROVIDER_ENABLED=true
SCF_CONTRACT_SIGN_HTTP_BASE_URL=https://sandbox.esign-vendor.example.com
SCF_CONTRACT_SIGN_HTTP_APP_ID=CHANGE_ME_VENDOR_APP_ID
SCF_CONTRACT_SIGN_HTTP_APP_SECRET=CHANGE_ME_VENDOR_APP_SECRET
SCF_CONTRACT_SIGN_HTTP_OUTBOUND_AUTH_MODE=HMAC_SHA256
# RSA/SM2: set OUTBOUND_AUTH_MODE and PRIVATE_KEY_PEM instead of APP_SECRET
# SCF_CONTRACT_SIGN_HTTP_PRIVATE_KEY_PEM=

# ── Optional DB trace export (staging Postgres) ─────────────────────────────
SCF_DB_HOST=staging-db.example.com
SCF_DB_PORT=5432
SCF_DB_NAME=scf
SCF_DB_USER=scf
SCF_DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── Planned production grayscale (applied AFTER Go/No-Go PASS) ───────────────
SCF_CONTRACT_SIGN_ROLLOUT_MODE=ALLOWLIST
SCF_CONTRACT_SIGN_ROLLOUT_PRODUCTION_PROVIDER=ESIGN_HTTP
SCF_CONTRACT_SIGN_ROLLOUT_FALLBACK_PROVIDER=MOCK
SCF_CONTRACT_SIGN_ROLLOUT_PROJECT_ALLOWLIST=PJ_PILOT_001
SCF_CONTRACT_SIGN_ROLLOUT_REQUIRE_HTTP_CONFIGURED=true
SCF_CONTRACT_SIGN_ROLLOUT_BLOCK_WHEN_MISCONFIGURED=true

# ── Go/No-Go metadata ───────────────────────────────────────────────────────
EA048_RUN_BY=CHANGE_ME_OPERATOR_NAME
EA048_ROLLBACK_ACK=yes
EA048_SIGN_OFF_ROLE=platform-ops
