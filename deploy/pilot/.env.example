# EA-032 Pilot Launch — Environment Variable Checklist
# Copy to .env (never commit real secrets). Inject via K8s Secret / VM env / CI.

# ── Database (PostgreSQL 14+) ─────────────────────────────────────────────
SCF_DB_HOST=localhost
SCF_DB_PORT=5432
SCF_DB_NAME=scf
SCF_DB_USER=scf
SCF_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Spring override (optional, assembled in application-prod.yml):
# SPRING_DATASOURCE_URL=jdbc:postgresql://${SCF_DB_HOST}:${SCF_DB_PORT}/${SCF_DB_NAME}

# ── Backend (Spring Boot) ─────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
# Context path fixed in app: /api/v1

# JWT — min 256 bits, unique per environment
SCF_JWT_SECRET=CHANGE_ME_MIN_256_BITS_RANDOM_STRING
SCF_JWT_EXPIRATION_MS=86400000

# Bank callback HMAC/token (replace mock in prod)
SCF_BANK_CALLBACK_TOKEN=CHANGE_ME_BANK_CALLBACK_TOKEN

# File storage (pilot: local disk; prod: mount or object storage path)
SCF_FILE_STORAGE_DIR=/var/scf/uploads
SCF_FILE_STORAGE_BUCKET=pilot-local
SCF_FILE_MAX_SIZE_BYTES=10485760

# Saga / Outbox schedulers (ms)
SCF_OUTBOX_POLL_INTERVAL_MS=30000
SCF_COMPENSATION_POLL_INTERVAL_MS=30000

# Idempotency record retention
SCF_IDEMPOTENCY_RETENTION_DAYS=180

# Logging
SCF_LOG_LEVEL_ROOT=INFO
SCF_LOG_LEVEL_COM_SCF=INFO
# Optional: file:/etc/scf/logback-spring.xml (see deploy/pilot/logging/LOGBACK_MOUNT_EVAL.md)
# SCF_LOGBACK_CONFIG=file:/etc/scf/logback-spring.xml

# Dev-only — MUST be false / unset in pilot prod
SCF_DEV_PASSWORD_BOOTSTRAP=false

# ── Frontend (static build or Vite preview) ───────────────────────────────
# API is proxied as /api/v1 in dev; prod nginx should reverse-proxy to backend
SCF_WEB_PUBLIC_URL=https://pilot.example.com
SCF_API_UPSTREAM=http://127.0.0.1:8080

# Smoke / CI (optional)
SMOKE_BASE_URL=http://127.0.0.1:5173
SMOKE_SKIP_WEBSERVER=1

# ── Ops contacts (for runbook, not consumed by app) ───────────────────────
SCF_OPS_ONCALL=ops@example.com
SCF_OPS_ESCALATION=platform-lead@example.com
