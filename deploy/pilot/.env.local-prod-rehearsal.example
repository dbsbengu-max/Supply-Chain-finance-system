# Local prod-profile rehearsal (NOT staging Go) — copy to .env.local-prod-rehearsal
#   copy .env.local-prod-rehearsal.example .env.local-prod-rehearsal
#   .\scripts\run-local-prod-rehearsal.ps1

SCF_ENV_NAME=local-prod-rehearsal
SCF_WEB_PUBLIC_URL=http://127.0.0.1:5173

SCF_DB_HOST=localhost
SCF_DB_PORT=5432
SCF_DB_NAME=scf
SCF_DB_USER=scf
SCF_DB_PASSWORD=scf_dev_pass

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
SCF_API_HEALTH_URL=http://127.0.0.1:8080/api/v1/actuator/health
SCF_API_UPSTREAM=http://127.0.0.1:8080

# Min 256-bit secrets — change if reusing outside localhost
SCF_JWT_SECRET=local-rehearsal-jwt-secret-change-me-min-256-bits-abc123xyz!!
SCF_JWT_EXPIRATION_MS=86400000
SCF_BANK_CALLBACK_TOKEN=local-rehearsal-bank-callback-token-not-for-prod

SCF_FILE_STORAGE_DIR=./data/uploads
SCF_FILE_STORAGE_BUCKET=local-rehearsal
SCF_DEV_PASSWORD_BOOTSTRAP=false

SCF_LOG_LEVEL_ROOT=INFO
SCF_LOG_LEVEL_COM_SCF=INFO

SMOKE_BASE_URL=http://127.0.0.1:5173
SMOKE_SKIP_WEBSERVER=1

SCF_OPS_ONCALL=local-rehearsal@example.com
SCF_OPS_ESCALATION=platform-lead@example.com
