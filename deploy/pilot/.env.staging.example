# EA-034 Staging — copy to .env on the STAGING jump box (never commit .env)
#   copy .env.staging.example .env
#   fill placeholders below, then: .\scripts\run-staging-validation.ps1

# ── Staging identity ───────────────────────────────────────────────────────
SCF_ENV_NAME=staging
SCF_WEB_PUBLIC_URL=https://staging-scf.example.com

# ── Database (staging PostgreSQL 14+) ───────────────────────────────────────
SCF_DB_HOST=staging-pg.internal.example.com
SCF_DB_PORT=5432
SCF_DB_NAME=scf
SCF_DB_USER=scf
SCF_DB_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD

# ── Backend (must match deployed staging app) ───────────────────────────────
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
SCF_API_HEALTH_URL=http://staging-scf-backend.internal:8080/api/v1/actuator/health
SCF_API_UPSTREAM=http://staging-scf-backend.internal:8080

# JWT — unique per environment, min 256 bits (NOT dev secret)
SCF_JWT_SECRET=CHANGE_ME_STAGING_JWT_MIN_256_BITS
SCF_JWT_EXPIRATION_MS=86400000
SCF_BANK_CALLBACK_TOKEN=CHANGE_ME_STAGING_BANK_TOKEN
SCF_CONTRACT_SIGN_DEFAULT_PROVIDER=ESIGN_HTTP
SCF_CONTRACT_SIGN_CALLBACK_TOKEN=CHANGE_ME_STAGING_CONTRACT_CALLBACK_HMAC_SECRET
SCF_CONTRACT_SIGN_CALLBACK_VERIFICATION_MODE=TIMESTAMP_NONCE_SIGNATURE
SCF_CONTRACT_SIGN_CALLBACK_SIGNATURE_WINDOW_SECONDS=300
SCF_CONTRACT_SIGN_HTTP_PROVIDER_ENABLED=true
SCF_CONTRACT_SIGN_HTTP_PROVIDER_CODE=ESIGN_HTTP
SCF_CONTRACT_SIGN_HTTP_PROVIDER_DISPLAY_NAME=HTTP电子签章
SCF_CONTRACT_SIGN_HTTP_BASE_URL=https://staging-esign-vendor.example.com
SCF_CONTRACT_SIGN_HTTP_CREATE_PATH=/sign/create
SCF_CONTRACT_SIGN_HTTP_STATUS_PATH=/sign/status/{externalSignRef}
SCF_CONTRACT_SIGN_HTTP_APP_ID=CHANGE_ME_STAGING_ESIGN_APP_ID
SCF_CONTRACT_SIGN_HTTP_APP_SECRET=CHANGE_ME_STAGING_ESIGN_APP_SECRET
SCF_CONTRACT_SIGN_HTTP_OUTBOUND_AUTH_MODE=HMAC_SHA256
SCF_CONTRACT_SIGN_HTTP_PLATFORM_TRACE_HEADER=X-Request-Id
SCF_CONTRACT_SIGN_HTTP_VENDOR_REQUEST_ID_HEADER=X-Vendor-Request-Id
SCF_CONTRACT_SIGN_HTTP_VENDOR_TRACE_ID_HEADER=X-Vendor-Trace-Id
SCF_BASE_URL=http://staging-scf-backend.internal:8080/api/v1

SCF_FILE_STORAGE_DIR=/var/scf/staging/uploads
SCF_FILE_STORAGE_BUCKET=staging
SCF_DEV_PASSWORD_BOOTSTRAP=false

SCF_LOG_LEVEL_ROOT=INFO
SCF_LOG_LEVEL_COM_SCF=INFO
# SCF_LOGBACK_CONFIG=file:/etc/scf/logback-spring.xml

# ── Frontend smoke (Vite dev or nginx URL reachable from jump box) ─────────
SMOKE_BASE_URL=http://127.0.0.1:5173
SMOKE_SKIP_WEBSERVER=1

# ── Ops (for escalation during validation) ─────────────────────────────────
SCF_OPS_ONCALL=ops@example.com
SCF_OPS_ESCALATION=platform-lead@example.com

# ── Executor (filled when running validation — optional) ───────────────────
# STAGING_VALIDATION_RUN_BY=zhangsan
# STAGING_VALIDATION_TICKET=REL-2026-001
