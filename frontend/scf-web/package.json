{
  "name": "scf-web",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "smoke": "node scripts/run-smoke.mjs",
    "smoke:direct": "playwright test tests/smoke --config=playwright.config.ts",
    "smoke:local": "powershell -ExecutionPolicy Bypass -File scripts/run-smoke-local.ps1",
    "smoke:install": "playwright install chromium"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "echarts": "^6.1.0",
    "element-plus": "^2.7.8",
    "pinia": "^2.1.7",
    "vue": "^3.4.31",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "playwright": "^1.60.0",
    "typescript": "^5.5.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^5.3.4",
    "vue-tsc": "^2.0.26"
  }
}
